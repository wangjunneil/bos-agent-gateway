# ============================================================================
# BOS Agent Gateway — Environment Configuration
# ============================================================================
# Copy this file to .env and modify values as needed.
# Generate a secure ADMIN_API_KEY with: openssl rand -hex 32
# ============================================================================

# --- Authentication ---
# Admin API key used for initial login. Keep this secret!
ADMIN_API_KEY=sk-change-me-to-a-secure-random-string
ADMIN_USERNAME=admin

# --- Database ---
# SQLite connection URL (aiosqlite async driver)
DATABASE_URL=sqlite+aiosqlite:///./gateway.db

# --- Health Polling ---
# Background task periodically checks registered Dify apps via /v1/info
HEALTH_POLL_ENABLED=true
HEALTH_POLL_INTERVAL_SECONDS=60

# --- Rate Limiting ---
# Per-user requests-per-minute limit (in-memory sliding window)
RATE_LIMIT_ENABLED=true
RATE_LIMIT_DEFAULT_RPM=60

# --- Redis Cache ---
# Optional. Set REDIS_ENABLED=false to disable.
# Caches task_id → conversation_id mappings and powers /v1/sessions/task-id
REDIS_ENABLED=true
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_USERNAME=
REDIS_PASSWORD=

# --- Debug ---
# Set to true for verbose SQL logging and detailed error traces
DEBUG=false
